{
  "name": "saikaku-ryoiki",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node node_modules/vite/bin/vite.js build",
    "preview": "node node_modules/vite/bin/vite.js preview",
    "test": "vitest run --config vitest.ui.config.js",
    "test:watch": "vitest --config vitest.ui.config.js",
    "emu": "PATH=/opt/homebrew/opt/openjdk@21/bin:$PATH firebase emulators:start --project demo-saikaku",
    "api": "node server.js",
    "dev:local": "concurrently -n emu,api,web -c yellow,cyan,green \"npm:emu\" \"npm:api\" \"npm:dev\"",
    "test:unit": "vitest run tests/unit src/screens/__tests__",
    "test:rules": "PATH=/opt/homebrew/opt/openjdk@21/bin:$PATH firebase emulators:exec --only firestore --project demo-saikaku 'vitest run tests/rules'",
    "test:api": "PATH=/opt/homebrew/opt/openjdk@21/bin:$PATH firebase emulators:exec --only auth,firestore --project demo-saikaku 'cross-env NODE_ENV=test MOCK_ANTHROPIC=1 TEST_BYPASS_AUTH=1 vitest run tests/api'",
    "test:e2e": "PATH=/opt/homebrew/opt/openjdk@21/bin:$PATH node scripts/test-e2e-orchestrator.mjs",
    "test:all": "npm run test:unit && npm test && npm run test:rules && npm run test:api && npm run test:e2e"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chart.js": "^4.4.6",
    "d3": "^7.9.0",
    "firebase": "^10.14.1",
    "firebase-admin": "^12.7.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.2",
    "nodemailer": "^8.0.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase-tools": "^15.15.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.48",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.15",
    "vite": "^5.4.10",
    "vitest": "^4.1.4",
    "wait-on": "^9.0.5"
  }
}
