# ========================================
# フロントエンド用 (Vite - VITE_ プレフィックス必須)
# ========================================

# Firebase クライアント設定（Firebase Console > プロジェクト設定 > アプリ から取得）
VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# 管理者メールアドレス（カンマ区切りで複数指定可）
VITE_ADMIN_EMAILS=haru@example.com,admin@example.com

# ========================================
# バックエンド用 (Vercel Serverless Functions)
# ========================================

# Anthropic API キー
ANTHROPIC_API_KEY=sk-ant-...

# Firebase Admin SDK（Firebase Console > プロジェクト設定 > サービスアカウント から生成）
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# 管理者メールアドレス（バックエンド用、VITE_ なし）
ADMIN_EMAILS=haru@example.com,admin@example.com
